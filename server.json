{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.xmqywx/shopify-store",
  "description": "MCP server for Shopify store management — products, orders, inventory, customers, collections, and analytics. 16 tools for e-commerce automation.",
  "repository": {
    "url": "https://github.com/xmqywx/shopify-mcp-server",
    "source": "github"
  },
  "version": "1.0.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@xmqywxkris/shopify-store-mcp",
      "version": "1.0.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Shopify store domain (e.g., my-store.myshopify.com)",
          "isRequired": true,
          "format": "string",
          "isSecret": false,
          "name": "SHOPIFY_STORE_DOMAIN"
        },
        {
          "description": "Shopify Admin API access token",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "SHOPIFY_ACCESS_TOKEN"
        }
      ]
    }
  ]
}
